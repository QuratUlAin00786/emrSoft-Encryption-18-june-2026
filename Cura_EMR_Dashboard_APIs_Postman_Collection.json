              "host": ["{{base_url}}"],
              "path": ["dashboard", "stats"]
            },
            "description": "Get dashboard statistics for admin role. Returns total patients, today's appointments, AI suggestions, and revenue."
          },
          "response": [
            {
              "name": "Success Response",
              "originalRequest": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{auth_token}}"
                  },
                  {
                    "key": "X-Tenant-Subdomain",
                    "value": "{{tenant_subdomain}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/dashboard/stats",
                  "host": ["{{base_url}}"],
                  "path": ["dashboard", "stats"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "cookie": [],
              "body": "{\n  \"totalPatients\": 150,\n  \"todayAppointments\": 12,\n  \"aiSuggestions\": 5,\n  \"revenue\": 50000\n}"
            },
            {
              "name": "Error Response",
              "originalRequest": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{auth_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/dashboard/stats",
                  "host": ["{{base_url}}"],
                  "path": ["dashboard", "stats"]
                }
              },
              "status": "Internal Server Error",
              "code": 500,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "cookie": [],
              "body": "{\n  \"error\": \"Failed to fetch dashboard stats\"\n}"
