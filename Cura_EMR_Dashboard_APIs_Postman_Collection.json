{
  "info": {
    "name": "Cura EMR - Dashboard APIs (Admin, Doctor, Nurse, Patient)",
    "description": "Complete dashboard API collection for all user roles with headers, payloads, and expected responses",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "cura-emr-dashboard"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://app.curaemr.ai/api",
      "type": "string"
    },
    {
      "key": "local_url",
      "value": "http://localhost:1100/api",
      "type": "string"
    },
    {
      "key": "tenant_subdomain",
      "value": "demo",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Universal Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.token) {",
                  "        pm.collectionVariables.set('auth_token', jsonData.token);",
                  "        pm.collectionVariables.set('tenant_subdomain', jsonData.organization?.subdomain || 'demo');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/universal-login",
              "host": ["{{base_url}}"],
              "path": ["auth", "universal-login"]
            },
            "description": "Login to get authentication token. Update email and password in body."
          },
          "response": []
        }
      ]
    },
